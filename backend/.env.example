PORT=5000
NODE_ENV=development

# Database Settings (Google Cloud SQL PostgreSQL)
DB_USER=postgres
DB_PASS=change-me-strong-password
DB_NAME=recipedb
DB_HOST=127.0.0.1
DB_PORT=5432

# GCP settings
GCP_PROJECT_ID=your-gcp-project-id
GCS_BUCKET_NAME=your-recipe-images-bucket
BQ_DATASET_NAME=recipe_analytics

# Local development credentials (leave empty if using ADC or running on GCP Cloud Run)
# GOOGLE_APPLICATION_CREDENTIALS=../credentials.json
